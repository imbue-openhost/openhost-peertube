# Tiny Caddy mid-tier whose only job is to rewrite the Host header
# from X-Forwarded-Host before forwarding to PeerTube on the
# loopback port.
#
# Background: PeerTube's /api/v1/oauth-clients/local handler
# explicitly checks `req.headers.host == webserver.hostname[:port]`
# and returns 403 otherwise. This is a hard-coded sanity check
# that ensures clients fetching OAuth tokens are talking to the
# canonical hostname (and not, say, a misconfigured reverse
# proxy that accidentally exposes the local-loopback API to a
# different vhost).
#
# Without rewriting, by the time a request reaches PeerTube the
# Host header is some loopback variant (the OpenHost router and
# the auth-proxy sidecar above us both forward to us by
# 127.0.0.1:<their_upstream_port>) — which never matches the
# canonical hostname and trips the 403. The OpenHost router DOES
# set X-Forwarded-Host correctly, so we rewrite Host from that
# header before the request hits PeerTube.  The auth-proxy
# preserves X-Forwarded-Host on its way through.
#
# Topology:
#
#   OpenHost router  →  127.0.0.1:9000  (auth-proxy.py / SSO sidecar)
#                   →  127.0.0.1:9090  (this Caddy)
#                   →  127.0.0.1:9001  (PeerTube node)
#
# The auth-proxy fronts Caddy because it's the layer that
# selectively bounces zone owners to the in-PeerTube SSO plugin
# (peertube-plugin-auth-openhost-sso, installed by start.sh on
# first boot) and strips X-OpenHost-* trust headers from inbound
# requests.  Federation traffic, anonymous viewer traffic, and
# already-authenticated owner traffic all pass through the
# auth-proxy unchanged; only the first-time owner navigation
# is bounced to /plugins/auth-openhost-sso/router/auto-login.
#
# This Caddy stays in the path because the Host-rewriting job
# is non-trivial to do safely from Python (we'd have to rebuild
# the request line and reattach all the X-Forwarded-* headers
# correctly), and Caddy is rock-solid at it.

{
	# No admin API, no automatic HTTPS — we are loopback-only.
	# auto_https off keeps Caddy from trying to provision certs
	# for the bare hostname (which would fail and noisily retry).
	admin off
	auto_https off
	# Caddy's default error log goes to stderr, which is what
	# the OpenHost log pipeline reads. Keep it minimal so we
	# don't drown out PeerTube's own logs.
	log {
		level WARN
		output stderr
	}
}

# Caddy listens on 127.0.0.1:9090 — loopback only.  The auth-proxy
# sidecar sits in front of it on :9000 (the port advertised in
# openhost.toml) and is the only thing that should reach Caddy.
# Binding loopback ensures a hostile container neighbour or a
# misconfigured router can't talk to Caddy directly and skip the
# auth-proxy's header sanitation.
#
# Note on Caddyfile syntax: the site address is plain ``:9090``
# (matches all Hosts) and the loopback restriction is expressed
# via the ``bind`` directive.  An address-prefix form like
# ``127.0.0.1:9090 { ... }`` would be interpreted by Caddy as a
# Host MATCHER (only respond to requests whose Host header equals
# ``127.0.0.1``) — which silently breaks all real requests, since
# our inbound traffic carries Host: 127.0.0.1:9090 (with the port).
:9090 {
	bind 127.0.0.1

	# /api/v1/oauth-clients/local hands the SPA the random
	# clientId/clientSecret pair PeerTube generates on first
	# boot.  PeerTube's response carries an ETag but no
	# ``Cache-Control`` header, so browsers cache the body
	# indefinitely and revalidate via If-None-Match on the
	# next visit.  In normal operation that's harmless, but
	# our deploy lifecycle can rotate the underlying
	# ``oAuthClient`` row (e.g. if an operator wipes app data
	# and redeploys, or the package gets reinstalled with
	# fresh secrets), and any browser whose cache predates
	# the rotation will go on POSTing the OLD client_id /
	# client_secret pair to /api/v1/users/token, where
	# PeerTube responds with the cryptic ``Invalid client:
	# client is invalid`` and the SPA's login flow dead-ends
	# until the operator clears site data.
	#
	# Adding ``Cache-Control: no-store`` makes the SPA always
	# re-fetch the live values, turning the rotation case
	# from "permanent login failure" into "one extra GET on
	# next page load."  The endpoint is hit at most once per
	# SPA session, so the cost of disabling caching is
	# essentially zero.  This handler MUST come before the
	# ``@has_xfh`` block below — Caddy evaluates handlers in
	# order, first matching wins.
	@oauth_client path /api/v1/oauth-clients/local
	handle @oauth_client {
		# Force-set the response headers regardless of what
		# PeerTube returns.  ``defer`` runs after the
		# upstream's response headers are merged so we clobber
		# any upstream Cache-Control / Pragma rather than
		# getting clobbered.  PeerTube currently emits neither
		# (just an ETag), so the overrides are belt-and-
		# suspenders, but the ETag strip IS necessary —
		# otherwise an old browser cache + a fresh ETag match
		# would let the SPA reuse a stale body even though
		# Cache-Control would have prevented the cache.
		#
		# The block form (``header { ... }``) is the only way
		# in Caddy v2's Caddyfile to attach ``defer`` to a
		# group of header directives.  Bare ``header Foo bar
		# defer`` would be parsed as a four-arg replace
		# (matcher / field / search-regex / replacement), not
		# as a deferred set.
		header {
			Cache-Control "no-store"
			Pragma "no-cache"
			-ETag
			defer
		}
		# Same proxy body as the other handlers below — kept
		# duplicated rather than DRYed via a snippet because
		# Caddy's snippet evaluation order interacts oddly
		# with header directives across handlers.
		request_header Host {header.X-Forwarded-Host}
		reverse_proxy 127.0.0.1:9001 {
			header_up X-Forwarded-For    {header.X-Forwarded-For}
			# X-Forwarded-Proto: see the comment block on the
			# default handler below for why we force ``https``
			# here rather than passing through the inbound
			# header.
			header_up X-Forwarded-Proto  https
			header_up X-Forwarded-Host   {header.X-Forwarded-Host}
		}
	}

	# Default handler chain for every other request.  Rewrites
	# the Host header from X-Forwarded-Host before proxying to
	# PeerTube on its loopback port.  If the header is absent
	# (which would only happen if something other than the
	# OpenHost router talked to us — there shouldn't be such
	# a path on a real deploy), fall through to whatever Host
	# the client sent.  ``request_header Host
	# {header.X-Forwarded-Host}`` rewrites the header on the
	# REQUEST forwarded to the backend, not the response.
	@has_xfh header X-Forwarded-Host *
	handle @has_xfh {
		request_header Host {header.X-Forwarded-Host}
		reverse_proxy 127.0.0.1:9001 {
			# Preserve the X-Forwarded-* headers the OpenHost
			# router stamped on the request. Caddy's default
			# is to set/append them, which would clobber the
			# router's value with Caddy's view of the client
			# IP (127.0.0.1, the router itself).
			header_up X-Forwarded-For    {header.X-Forwarded-For}
			# X-Forwarded-Proto is force-set to ``https``
			# rather than passed through.  Background: the
			# OpenHost router (compute_space) runs hypercorn
			# without ProxyFixMiddleware, so it sees the
			# inbound connection from the public Caddy
			# (loopback, plain HTTP) as scheme=http and
			# overwrites X-Forwarded-Proto with ``http``
			# before forwarding to us — even when the
			# original browser request was HTTPS.  PeerTube's
			# resumable-upload library (@uploadx/core) reads
			# X-Forwarded-Proto verbatim to construct the
			# absolute Location header it returns to the
			# browser, so an inbound ``http`` produces a
			# ``http://...`` upload URL on a HTTPS page —
			# which the browser blocks as Mixed Content,
			# making video uploads fail with an opaque
			# "Unknown error".  Forcing ``https`` here is
			# safe: this Caddy is loopback-only, only the
			# auth-proxy talks to it, the auth-proxy only
			# accepts requests forwarded by the OpenHost
			# router, and the OpenHost router only listens
			# behind the public TLS-terminating Caddy on
			# :443.  HTTP cannot reach this socket.  The
			# correct long-term fix is to wire ProxyFix into
			# compute_space; this is a tactical workaround
			# pending that change.
			header_up X-Forwarded-Proto  https
			header_up X-Forwarded-Host   {header.X-Forwarded-Host}
			# WebSocket upgrade handling is automatic in
			# reverse_proxy; PeerTube uses ws for live
			# transcoding job updates and the embed player.
		}
	}
	handle {
		# Fallback path — fires only if X-Forwarded-Host is
		# missing, which shouldn't happen on a real deploy
		# (the OpenHost router always stamps it).  Still set
		# X-Forwarded-Proto: https for the same reason as the
		# main handler above; otherwise Caddy's default would
		# stamp ``http`` (the listener scheme on this loopback
		# socket) and we'd be back to the Mixed Content
		# upload bug on this codepath.
		reverse_proxy 127.0.0.1:9001 {
			header_up X-Forwarded-Proto https
		}
	}
}
